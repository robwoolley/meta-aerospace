+[build-system]
+requires = ["setuptools>=61"]
+build-backend = "setuptools.build_meta"
+
+[project]
+name = "genmsg"
+version = "0.6.1"
+description = "Standalone Python library for generating ROS message and service data structures for various languages."
+readme = "README.md"
+license = {text = "BSD-3-Clause"}
+requires-python = ">=3.6"
+authors = [
+    {name = "Troy Straszheim"},
+    {name = "Morten Kjaergaard"},
+    {name = "Ken Conley"},
+    {name = "Dirk Thomas", email = "dthomas@osrfoundation.org"},
+]
+maintainers = [
+    {name = "Dirk Thomas", email = "dthomas@osrfoundation.org"},
+]
+dependencies = [
+    "empy",
+]
+
+[project.urls]
+Homepage = "http://wiki.ros.org/genmsg"
+Repository = "https://github.com/ros/genmsg"
+Issues = "https://github.com/ros/genmsg/issues"
+
+[project.scripts]
+genmsg_check_deps = "genmsg.check_deps:main"
+
+[tool.setuptools.packages.find]
+where = ["src"]
+
+[tool.pytest.ini_options]
+testpaths = ["test"]
+pythonpath = ["src"]
