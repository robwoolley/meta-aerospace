diff --git a/tools/elf2cfetbl/CMakeLists.txt b/tools/elf2cfetbl/CMakeLists.txt
index 818065d..6d4f9dc 100644
--- a/tools/elf2cfetbl/CMakeLists.txt
+++ b/tools/elf2cfetbl/CMakeLists.txt
@@ -13,7 +13,7 @@ add_custom_target(tabletool-execute
         CC="${CMAKE_C_COMPILER}"
         CFLAGS="${CMAKE_C_FLAGS}"
         AR="${CMAKE_AR}"
